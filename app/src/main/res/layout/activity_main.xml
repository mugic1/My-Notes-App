<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- 📁 SIDEBAR GRID PANEL (Notes List & Navigation) -->
    <LinearLayout
        android:id="@+id/sidebarLayout"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp">

        <Button
            android:id="@+id/buttonAddNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="➕ New Asset"
            android:textSize="14sp" />

        <ListView
            android:id="@+id/listViewNotes"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp" />

        <Button
            android:id="@+id/buttonSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="⚙️ Config Panel"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 📏 VERTICAL SPLIT SEPARATOR (Resizes automatically based on grid layout) -->
    <View
        android:id="@+id/verticalSeparator"
        android:layout_width="1dp"
        android:layout_height="match_parent" />

    <!-- 🖥️ RIGHT CONTENT WORKSPACE ROOT -->
    <FrameLayout
        android:id="@+id/rightPanelRoot"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <!-- 🌌 STATE 1: PLACEHOLDER VIEW (Default Empty State Screen) -->
        <LinearLayout
            android:id="@+id/layoutPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/textPlaceholderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DevCode IDE Workspace"
                android:textSize="22sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/textPlaceholderSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select an existing note asset or create a new file compile script."
                android:textSize="14sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- 📝 STATE 2: ACTIVE EDITOR CANVAS (Contains Document Editor & Toolbar) -->
        <LinearLayout
            android:id="@+id/layoutEditor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 🔥 PRO ADVANCED EDITING TOOLBAR (Highlighter, Todo, Reminders Hook) -->
            <LinearLayout
                android:id="@+id/layoutEditorToolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="6dp"
                android:gravity="center">

                <Button
                    android:id="@+id/buttonHighlight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="2dp"
                    android:text="✨ Highlight"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/buttonAddTask"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="2dp"
                    android:text="☑️ Task"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/buttonSetReminder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="2dp"
                    android:text="⏰ Reminder"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 📏 HORIZONTAL SEPARATOR -->
            <View
                android:id="@+id/titleSeparator"
                android:layout_width="match_parent"
                android:layout_height="1dp" />

            <!-- 📝 DOCUMENT TITLE INPUT -->
            <EditText
                android:id="@+id/editTextTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Note Title"
                android:background="@android:color/transparent"
                android:padding="12dp"
                android:textSize="22sp"
                android:inputType="text" />

            <!-- 🖋️ MAIN TEXT/CODE COMPILER CANVAS -->
            <EditText
                android:id="@+id/editTextContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="Start writing code, documentation or tasks here..."
                android:background="@android:color/transparent"
                android:padding="12dp"
                android:gravity="top"
                android:inputType="textMultiLine" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>